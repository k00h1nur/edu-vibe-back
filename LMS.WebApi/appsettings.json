{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=eduvibe_lms;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "EduVibe",
    "Audience": "EduVibeClients",
    "Key": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "Telegram": {
    "BotToken": "",
    "ManagerBotToken": "",
    "ChatId": "",
    "BotUsername": "platform_eduvibeBot",
    "MiniAppUrl": "https://admin.edu-vibe.uz",
    "QueueCapacity": 256,
    "MaxAttempts": 4,
    "RequestTimeoutSeconds": 10,
    "BaseBackoffMilliseconds": 250
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "DemoUsers": {
    "Enabled": false,
    "Password": "Demo!2026",
    "EmailDomain": "eduvibe.local"
  },
  "SuperAdmin": {
    "// Email": "Set to an existing account's email to grant it the SuperAdmin role on boot (idempotent, additive). Leave blank to keep the seeded director@eduvibe.local super-admin.",
    "Email": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  }
}
