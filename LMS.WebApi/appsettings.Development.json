{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Auto-top-up matrix grants on every boot. The seeder defaults to
  // bootstrap-once (skip roles that already have *any* grants), which
  // protects deliberate admin removals — but means new matrix entries
  // (Materials.Read, Practice.Read, Analytics.Read, …) never reach roles
  // that were seeded before those permissions existed. That's why the
  // teacher panel's sidebar looked empty save for Settings. Flip this to
  // false for production where admin removals must survive a restart.
  "RolePermissions": {
    "TopUpDefaults": true
  }
}
