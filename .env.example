# Copy to ".env" on the server (next to docker-compose.yml) and fill in.
# NEVER commit the populated .env.

# ---- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=eduvibe
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=eduvibe_lms

# ---- JWT ------------------------------------------------------------------
# Generate: openssl rand -base64 48
JWT_KEY=CHANGE_ME_random_64_char_secret
JWT_ISSUER=EduVibe
JWT_AUDIENCE=EduVibeClients

# ---- Telegram (required in Production — app will not boot if empty) -------
TELEGRAM_BOT_TOKEN=CHANGE_ME_from_botfather
TELEGRAM_CHAT_ID=CHANGE_ME_chat_id

# ---- CORS (required in Production — at least one origin) -------------------
# The frontend is served same-origin through nginx, so CORS isn't exercised in
# practice — but Production refuses to boot with an empty list. Use the server
# IP now; add the real domain here once you have one.
CORS_ORIGIN_0=http://SERVER_IP

# ---- Misc -----------------------------------------------------------------
DEMO_USERS_ENABLED=false

# Image refs — set by CI/CD at deploy time (sha-pinned). Defaults to latest for
# manual/local use.
IMAGE=ghcr.io/k00h1nur/edu-vibe-back:latest
WEB_IMAGE=ghcr.io/k00h1nur/edu-vibe:latest
