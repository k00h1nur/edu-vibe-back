{
  "// NOTE": "Copy to appsettings.Production.json OR set each value via environment variables (e.g. Jwt__Key, Telegram__BotToken). Do NOT commit the populated production file.",

  "ConnectionStrings": {
    "DefaultConnection": "Host=...;Port=5432;Database=...;Username=...;Password=..."
  },

  "Jwt": {
    "Issuer": "EduVibe",
    "Audience": "EduVibeClients",
    "Key": "REPLACE_WITH_RANDOM_64_CHAR_SECRET",
    "AccessTokenMinutes": 30
  },

  "Telegram": {
    "BotToken": "REPLACE_FROM_BOTFATHER",
    "ChatId": "REPLACE_WITH_CHAT_ID"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://app.eduvibe.example",
      "https://www.eduvibe.example"
    ]
  },

  "DemoUsers": {
    "Enabled": false
  },

  "RolePermissions": {
    "TopUpDefaults": false
  }
}
